// ==============================================================================
// @factiii/auth — DEVICE reference schema (legacy factiii mobile-bound flow)
// ==============================================================================
//
// Use this schema when running with `features.twoFaMode: 'device'`.
// 2FA secrets live per-session (`Session.twoFaSecret`), and enrollment is
// gated on a registered mobile device (`Device` table). The device's push
// token is reused as TOTP key material.
//
// **Most consumers do NOT want this** — use `schema.standard.prisma` for the
// normal user-centric TOTP flow. This file exists for `../factiii` and any
// other consumer that already runs the legacy mobile-bound flow.
// ==============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================================================================
// Enums
// ==============================================================================

enum UserStatus {
  ACTIVE
  DEACTIVATED
  BANNED
}

enum UserTag {
  HUMAN
  BOT
}

enum EmailVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

// ==============================================================================
// User Model
// ==============================================================================

model User {
  id                      Int                     @id @default(autoincrement())
  createdAt               DateTime                @default(now())
  // Required by AuthUser/runtime: login/refresh embed `updatedAt.toISOString()`
  // in the client cookie payload, and adapters select this column on every
  // session lookup. Without it, login crashes with
  // "Cannot read properties of undefined (reading 'toISOString')".
  updatedAt               DateTime                @default(now()) @updatedAt
  status                  UserStatus              @default(ACTIVE)
  email                   String                  @unique
  emailVerificationStatus EmailVerificationStatus @default(UNVERIFIED)
  password                String?
  username                String                  @unique
  twoFaEnabled            Boolean                 @default(false)
  oauthProvider           OAuthProvider?
  oauthId                 String?
  tag                     UserTag                 @default(HUMAN)
  isActive                Boolean                 @default(false)
  verifiedHumanAt         DateTime?
  otpForEmailVerification String?

  // Relations
  sessions       Session[]
  passwordReset  PasswordReset[]
  otps           OTP[]
  devices        Device[]        @relation("devices")
  admin          Admin?
  magicLinks     MagicLink[]
}

// ==============================================================================
// Session Model
// ==============================================================================

model Session {
  id          Int       @id @default(autoincrement())
  socketId    String?   @unique
  // Device-mode 2FA: TOTP secret lives per-session, scoped to the registered device.
  twoFaSecret String?   @unique
  issuedAt    DateTime  @default(now())
  browserName String    @default("Unknown")
  lastUsed    DateTime  @default(now()) @updatedAt
  device      Device?   @relation(fields: [deviceId], references: [id])
  deviceId    Int?
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt   DateTime?

  @@index([userId])
  @@index([deviceId])
}

// ==============================================================================
// Admin Model
// ==============================================================================

model Admin {
  ip     String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int    @unique

  @@id([userId])
}

// ==============================================================================
// PasswordReset Model
// ==============================================================================

model PasswordReset {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invalidatedAt DateTime?

  @@index([userId])
}

// ==============================================================================
// OTP Model
// ==============================================================================

model OTP {
  id        Int      @id @default(autoincrement())
  code      Int
  expiresAt DateTime
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==============================================================================
// Device Model — only required when features.twoFaMode is 'device'.
// ==============================================================================

model Device {
  id        Int       @id @default(autoincrement())
  pushToken String    @unique
  createdAt DateTime  @default(now())
  users     User[]    @relation("devices")
  sessions  Session[]
}

// ==============================================================================
// MagicLink Model (optional — enable with features.magicLink)
// ==============================================================================

model MagicLink {
  id        String    @id @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
