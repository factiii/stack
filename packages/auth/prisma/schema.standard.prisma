// ==============================================================================
// @factiii/auth — STANDARD reference schema
// ==============================================================================
//
// This is the default schema for new consumers. 2FA secrets live on the User
// row (`twoFaSecret`, `twoFaBackupCodes`) for a normal user-centric TOTP flow.
// There is NO `Device` model and Sessions have no per-session 2FA columns.
//
// If you need the legacy factiii mobile-bound flow (push-token-derived
// secrets, per-session twoFaSecret), use `schema.device.prisma` instead and
// pair it with `createPrismaDeviceAdapter` + `features.twoFaMode: 'device'`.
// ==============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================================================================
// Enums
// ==============================================================================

enum UserStatus {
  ACTIVE
  DEACTIVATED
  BANNED
}

enum UserTag {
  HUMAN
  BOT
}

enum EmailVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

// ==============================================================================
// User Model
// ==============================================================================

model User {
  id                      Int                     @id @default(autoincrement())
  createdAt               DateTime                @default(now())
  // Required by AuthUser/runtime: login/refresh embed `updatedAt.toISOString()`
  // in the client cookie payload, and the drizzle adapter selects this column
  // on every session lookup. Without it, login crashes with
  // "Cannot read properties of undefined (reading 'toISOString')".
  updatedAt               DateTime                @default(now()) @updatedAt
  status                  UserStatus              @default(ACTIVE)
  email                   String                  @unique
  emailVerificationStatus EmailVerificationStatus @default(UNVERIFIED)
  password                String?
  username                String                  @unique
  // Standard-mode 2FA: TOTP secret + single-use backup codes live on the user.
  // 2FA is "on" iff `twoFaSecret` is non-null — no separate enabled flag.
  twoFaSecret             String?
  twoFaBackupCodes        String[]                @default([])
  oauthProvider           OAuthProvider?
  oauthId                 String?
  tag                     UserTag                 @default(HUMAN)
  isActive                Boolean                 @default(false)
  verifiedHumanAt         DateTime?
  otpForEmailVerification String?

  // Relations
  sessions       Session[]
  passwordReset  PasswordReset[]
  otps           OTP[]
  admin          Admin?
  magicLinks     MagicLink[]
}

// ==============================================================================
// Session Model
// ==============================================================================

model Session {
  id          Int       @id @default(autoincrement())
  socketId    String?   @unique
  issuedAt    DateTime  @default(now())
  browserName String    @default("Unknown")
  lastUsed    DateTime  @default(now()) @updatedAt
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt   DateTime?

  @@index([userId])
}

// ==============================================================================
// Admin Model
// ==============================================================================

model Admin {
  ip     String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int    @unique

  @@id([userId])
}

// ==============================================================================
// PasswordReset Model
// ==============================================================================

model PasswordReset {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invalidatedAt DateTime?

  @@index([userId])
}

// ==============================================================================
// OTP Model
// ==============================================================================

model OTP {
  id        Int      @id @default(autoincrement())
  code      Int
  expiresAt DateTime
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==============================================================================
// MagicLink Model (optional — enable with features.magicLink)
// ==============================================================================

model MagicLink {
  id        String    @id @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
