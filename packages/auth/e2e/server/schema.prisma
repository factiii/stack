generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
  BANNED
}

enum UserTag {
  HUMAN
  BOT
}

enum EmailVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

model User {
  id                      Int                     @id @default(autoincrement())
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  status                  UserStatus              @default(ACTIVE)
  email                   String                  @unique
  emailVerificationStatus EmailVerificationStatus @default(UNVERIFIED)
  password                String?
  username                String                  @unique
  twoFaSecret             String?
  twoFaBackupCodes        String[]                @default([])
  oauthProvider           OAuthProvider?
  oauthId                 String?
  tag                     UserTag                 @default(HUMAN)
  isActive                Boolean                 @default(false)
  verifiedHumanAt         DateTime?
  otpForEmailVerification String?

  sessions      Session[]
  passwordReset PasswordReset[]
  otps          OTP[]
  admin         Admin?
}

model Session {
  id          Int       @id @default(autoincrement())
  socketId    String?   @unique
  issuedAt    DateTime  @default(now())
  browserName String    @default("Unknown")
  lastUsed    DateTime  @default(now()) @updatedAt
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt   DateTime?

  @@index([userId])
}

model Admin {
  ip     String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int    @unique

  @@id([userId])
}

model PasswordReset {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invalidatedAt DateTime?

  @@index([userId])
}

model OTP {
  id        Int      @id @default(autoincrement())
  code      Int
  expiresAt DateTime
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
